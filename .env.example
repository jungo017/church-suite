# ─────────────────────────────────────────────────────────────
# church-suite 환경 변수 예시 — 복사해서 .env 로 사용하세요.
#   cp .env.example .env
# .env 는 git에 커밋되지 않습니다(.gitignore). 이 예시만 커밋됩니다.
# ─────────────────────────────────────────────────────────────

# PostgreSQL (docker-compose.yml 의 기본값과 일치)
# 5432가 이미 사용 중이면 DB_PORT 로 호스트 포트를 바꾸고 아래 URL 들의 포트도 맞추세요.
# DB_PORT=5432
#
# DATABASE_URL     = 마이그레이션/관리용 슈퍼유저(church). drizzle-kit 이 사용.
# APP_DATABASE_URL = 앱 런타임용 비슈퍼유저(church_app). lib/db 가 사용(RLS 적용 대상).
#   RLS 는 슈퍼유저에 적용되지 않으므로 앱은 반드시 church_app 으로 접속해야 한다(스펙 §5).
#   church_app 롤은 마이그레이션 0003_app_role 에서 생성된다.
DATABASE_URL=postgresql://church:church@localhost:5432/church_suite
APP_DATABASE_URL=postgresql://church_app:church_app@localhost:5432/church_suite

# Node 환경
NODE_ENV=development

# 테넌트 루트 도메인 — 서브도메인 추출 기준(`<교회코드>.<root>`).
# 로컬: localhost (예: cityhope.localhost). 운영: 실제 도메인(예: churchsuite.kr).
NEXT_PUBLIC_ROOT_DOMAIN=localhost

# ── 이후 Phase에서 사용 (지금은 placeholder) ───────────────────
# 인증 (Phase 0.5) — JWT_SECRET 필수(긴 랜덤 문자열). 운영에선 비밀로 관리.
#   예: openssl rand -hex 32
JWT_SECRET=replace-with-a-long-random-secret
# 토큰 수명(초). 미설정 시 기본 900(15분) / 2592000(30일).
# JWT_ACCESS_TTL_SEC=900
# JWT_REFRESH_TTL_SEC=2592000

# 파일 저장소 / S3 호환 (SeaweedFS/MinIO/AWS S3, §10)
# STORAGE_DRIVER=local        # local(기본) | s3
# 기본 드라이버(local)는 저장 루트를 반드시 지정해야 한다(STORAGE_LOCAL_DIR).
STORAGE_LOCAL_DIR=.storage
# ── s3 사용 시(아래 SeaweedFS 로컬 예시 — docker compose --profile storage up -d) ──
# STORAGE_DRIVER=s3
# STORAGE_ENDPOINT=http://localhost:8333
# STORAGE_REGION=us-east-1     # SeaweedFS 는 무시(SDK 요구값)
# STORAGE_BUCKET=church-suite
# STORAGE_ACCESS_KEY=any        # SeaweedFS 기본은 무인증(아무 값)
# STORAGE_SECRET_KEY=any

# 알림 채널 (SMS/알림톡, §14) — 기본 log(mock). 실채널은 드라이버 연동 후 설정.
# NOTIFY_DRIVER=log           # log(기본·mock) | aligo | sens | solapi …(연동 필요)
