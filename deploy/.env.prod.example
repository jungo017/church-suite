# church-suite 운영 환경 변수 — deploy/.env.prod 로 복사해 채우세요.
#   cp deploy/.env.prod.example deploy/.env.prod
# .env.prod 는 커밋 금지(.dockerignore/.gitignore).

# ── DB ───────────────────────────────────────────────────────────
# 마이그레이션/잡(pg-boss)은 슈퍼유저(church)로 Postgres 직접 접속.
# 앱 런타임은 비슈퍼유저(church_app)여야 RLS 가 적용된다(스펙 §5).
POSTGRES_PASSWORD=CHANGE_ME_postgres
DATABASE_URL=postgresql://church:CHANGE_ME_postgres@postgres:5432/church_suite

# church_app 기본 비밀번호는 마이그레이션 0003 에서 'church_app' 로 생성됨.
# ⚠️ 운영 배포 후 반드시 회전: ALTER ROLE church_app PASSWORD '...'; → 아래 URL 갱신.
APP_DB_PASSWORD=church_app
APP_DATABASE_URL=postgresql://church_app:church_app@postgres:5432/church_suite
# 다중 인스턴스 확장 시(profile scale) 앱은 PgBouncer 경유:
# APP_DATABASE_URL=postgresql://church_app:church_app@pgbouncer:6432/church_suite

NODE_ENV=production

# 테넌트 루트 도메인(서브도메인=교회코드). 예: example.com → cityhope.example.com
NEXT_PUBLIC_ROOT_DOMAIN=example.com

# 인증 — 반드시 긴 랜덤. openssl rand -hex 32
JWT_SECRET=CHANGE_ME_long_random_secret

# ── 저장소 ───────────────────────────────────────────────────────
# 다중 인스턴스에선 로컬 디스크가 공유되지 않으므로 s3(SeaweedFS) 권장(profile storage).
STORAGE_DRIVER=local
# local 드라이버 저장 루트(컨테이너 경로). compose 의 appstorage 볼륨 마운트와 일치해야 한다.
# (이미지 기본값도 /data/storage — 경로를 바꾸면 양쪽 다 맞추세요.)
STORAGE_LOCAL_DIR=/data/storage
# STORAGE_DRIVER=s3
# STORAGE_ENDPOINT=http://seaweedfs:8333
# STORAGE_REGION=us-east-1
# STORAGE_BUCKET=church-suite
# STORAGE_ACCESS_KEY=CHANGE_ME
# STORAGE_SECRET_KEY=CHANGE_ME

# ── 알림 채널(SMS/알림톡) ─────────────────────────────────────────
NOTIFY_DRIVER=log
# 실채널 연동 시 드라이버별 자격증명(§14)
